{
	"name": "better-comment-highlight",
	"displayName": "Better Comment Highlight",
	"description": "Highlights specific tags in comments (ERROR, WARN, NOTE, IDEA, etc.) with customizable colors for better code readability.",
	"version": "1.3.1",
	"publisher": "j2cks",
	"icon": "pic/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/teenageswag/VsCode-Better-Comments"
	},
	"keywords": [
		"comments",
		"highlight",
		"tags",
		"todo",
		"fixme",
		"note",
		"productivity"
	],
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Formatters",
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"configuration": {
			"title": "Better Comment Highlight",
			"properties": {
				"betterCommentTags.groups": {
					"type": "array",
					"default": [],
					"description": "Custom tag groups added to the default groups. If a custom group has the same name as a default group, it overrides it.",
					"items": {
						"type": "object",
						"properties": {
							"name": {
								"type": "string",
								"description": "Unique group name."
							},
							"tags": {
								"type": "array",
								"description": "Tags matched for this group (case-insensitive).",
								"items": {
									"type": "string"
								}
							},
							"color": {
								"type": "string",
								"description": "Text color for this group."
							},
							"backgroundColor": {
								"type": "string",
								"description": "Background color for this group. Leave empty for no background."
							},
							"fontWeight": {
								"type": "string",
								"enum": [
									"normal",
									"bold",
									"100",
									"200",
									"300",
									"400",
									"500",
									"600",
									"700",
									"800",
									"900"
								],
								"description": "Font weight for this group."
							}
						}
					}
				},
				"betterCommentTags.critical.color": {
					"type": "string",
					"default": "#FF2A3D",
					"description": "Text color for critical tags (ERROR, ERR, FIX, FIXME)."
				},
				"betterCommentTags.critical.backgroundColor": {
					"type": "string",
					"default": "",
					"description": "Background color for critical tags. Leave empty for no background."
				},
				"betterCommentTags.critical.fontWeight": {
					"type": "string",
					"default": "normal",
					"enum": [
						"normal",
						"bold",
						"100",
						"200",
						"300",
						"400",
						"500",
						"600",
						"700",
						"800",
						"900"
					],
					"description": "Font weight for critical tags."
				},
				"betterCommentTags.warning.color": {
					"type": "string",
					"default": "#FFAA33",
					"description": "Text color for warning tags (WARNING, WARN)."
				},
				"betterCommentTags.warning.backgroundColor": {
					"type": "string",
					"default": "",
					"description": "Background color for warning tags. Leave empty for no background."
				},
				"betterCommentTags.warning.fontWeight": {
					"type": "string",
					"default": "normal",
					"enum": [
						"normal",
						"bold",
						"100",
						"200",
						"300",
						"400",
						"500",
						"600",
						"700",
						"800",
						"900"
					],
					"description": "Font weight for warning tags."
				},
				"betterCommentTags.ideas.color": {
					"type": "string",
					"default": "#1AA9F5",
					"description": "Text color for idea tags (TODO, IDEA, OPTIMIZE)."
				},
				"betterCommentTags.ideas.backgroundColor": {
					"type": "string",
					"default": "",
					"description": "Background color for idea tags. Leave empty for no background."
				},
				"betterCommentTags.ideas.fontWeight": {
					"type": "string",
					"default": "normal",
					"enum": [
						"normal",
						"bold",
						"100",
						"200",
						"300",
						"400",
						"500",
						"600",
						"700",
						"800",
						"900"
					],
					"description": "Font weight for idea tags."
				},
				"betterCommentTags.info.color": {
					"type": "string",
					"default": "#6FEA2D",
					"description": "Text color for info tags (NOTE, INFO)."
				},
				"betterCommentTags.info.backgroundColor": {
					"type": "string",
					"default": "",
					"description": "Background color for info tags. Leave empty for no background."
				},
				"betterCommentTags.info.fontWeight": {
					"type": "string",
					"default": "normal",
					"enum": [
						"normal",
						"bold",
						"100",
						"200",
						"300",
						"400",
						"500",
						"600",
						"700",
						"800",
						"900"
					],
					"description": "Font weight for info tags."
				}
			}
		}
	},
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"package": "npx -y @vscode/vsce package --out better-comment-highlight.vsix"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@types/vscode": "^1.85.0",
		"typescript": "^5.3.3"
	}
}
